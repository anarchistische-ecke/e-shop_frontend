# frontend/.env.example
REACT_APP_API_BASE=http://localhost:8080
REACT_APP_IMAGE_BASE=
REACT_APP_DIRECTUS_BASE_URL=http://localhost:8055
# Optional. Only use a public read-only Directus token here if the public role is insufficient.
# Never put an admin or server-side static token into browser env vars.
REACT_APP_DIRECTUS_PUBLIC_TOKEN=
REACT_APP_KEYCLOAK_URL=http://localhost:8081
REACT_APP_KEYCLOAK_REALM=cozyhome
REACT_APP_KEYCLOAK_CLIENT_ID=cozyhome-web
REACT_APP_KEYCLOAK_IDP_YANDEX=yandex
REACT_APP_KEYCLOAK_IDP_VK=vk
REACT_APP_KEYCLOAK_CUSTOMER_ROLE=customer
REACT_APP_KEYCLOAK_MANAGER_ROLE=manager
REACT_APP_KEYCLOAK_ADMIN_ROLE=admin
REACT_APP_KEYCLOAK_ADMIN_ROLE_CLIENT=
REACT_APP_KEYCLOAK_LOCALE=ru
REACT_APP_YANDEX_METRIKA_ID=
REACT_APP_YANDEX_MAPS_JS_API_KEY=
REACT_APP_YANDEX_GEOCODER_API_KEY=
