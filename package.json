{
  "name": "cozyhome",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "express": "^4.21.2",
    "focus-trap-react": "^12.0.0",
    "keycloak-js": "^25.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.14",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.24",
    "supertest": "^7.1.1",
    "tailwindcss": "^3.3.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "start": "node server/index.mjs",
    "dev": "node server/index.mjs",
    "build": "vite build && vite build --ssr src/entry-server.jsx --outDir dist/server",
    "test": "vitest run",
    "test:watch": "vitest",
